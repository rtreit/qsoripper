# Local development template for QsoRipper QRZ integrations.
# Copy to .env (kept untracked) and set real values locally.
# Production/CI should inject these via environment or secret store.

QSORIPPER_ENV=development

# Optional override for the persisted setup file used by SetupService and server startup.
# QSORIPPER_CONFIG_PATH=.\config\qsoripper.toml

# Required by QRZ to identify client applications.
QSORIPPER_QRZ_USER_AGENT="QsoRipper/0.1.0 (YOURCALL)"

# QRZ Logbook API
QSORIPPER_QRZ_LOGBOOK_BASE_URL=https://logbook.qrz.com/api
# Separate logbook access key from the QRZ website. Do not reuse for XML login.
QSORIPPER_QRZ_LOGBOOK_API_KEY=REPLACE_WITH_QRZ_LOGBOOK_ACCESS_KEY

# QRZ XML Lookup API
QSORIPPER_QRZ_XML_BASE_URL=https://xmldata.qrz.com/xml/current/
# QRZ account username + actual QRZ password for XML lookup login.
QSORIPPER_QRZ_XML_USERNAME=REPLACE_WITH_QRZ_USERNAME
QSORIPPER_QRZ_XML_PASSWORD=REPLACE_WITH_QRZ_PASSWORD
# Optional diagnostics mode: capture outgoing request details without sending HTTP traffic.
# QSORIPPER_QRZ_XML_CAPTURE_ONLY=true

# Recommended network defaults
QSORIPPER_QRZ_HTTP_TIMEOUT_SECONDS=8
QSORIPPER_QRZ_MAX_RETRIES=2

# Optional active station profile used as the base snapshot for newly logged QSOs.
# QSORIPPER_STATION_PROFILE_NAME=Home
# QSORIPPER_STATION_CALLSIGN=K7DBG
# QSORIPPER_STATION_OPERATOR_CALLSIGN=K7DBG
# QSORIPPER_STATION_OPERATOR_NAME=Taylor Operator
# QSORIPPER_STATION_GRID=CN87up
# QSORIPPER_STATION_COUNTY=KING
# QSORIPPER_STATION_STATE=WA
# QSORIPPER_STATION_COUNTRY=United States
# QSORIPPER_STATION_DXCC=291
# QSORIPPER_STATION_CQ_ZONE=3
# QSORIPPER_STATION_ITU_ZONE=6
# QSORIPPER_STATION_LATITUDE=47.6062
# QSORIPPER_STATION_LONGITUDE=-122.3321
