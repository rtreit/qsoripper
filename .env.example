# Local development template for LogRipper QRZ integrations.
# Copy to .env (kept untracked) and set real values locally.
# Production/CI should inject these via environment or secret store.

LOGRIPPER_ENV=development

# Required by QRZ to identify client applications.
LOGRIPPER_QRZ_USER_AGENT=LogRipper/0.1.0 (YOURCALL)

# QRZ Logbook API
LOGRIPPER_QRZ_LOGBOOK_BASE_URL=https://logbook.qrz.com/api
# Separate logbook access key from the QRZ website. Do not reuse for XML login.
LOGRIPPER_QRZ_LOGBOOK_API_KEY=REPLACE_WITH_QRZ_LOGBOOK_ACCESS_KEY

# QRZ XML Lookup API
LOGRIPPER_QRZ_XML_BASE_URL=https://xmldata.qrz.com/xml/current/
# QRZ account username + actual QRZ password for XML lookup login.
LOGRIPPER_QRZ_XML_USERNAME=REPLACE_WITH_QRZ_USERNAME
LOGRIPPER_QRZ_XML_PASSWORD=REPLACE_WITH_QRZ_PASSWORD
# Optional diagnostics mode: capture outgoing request details without sending HTTP traffic.
# LOGRIPPER_QRZ_XML_CAPTURE_ONLY=true

# Recommended network defaults
LOGRIPPER_QRZ_HTTP_TIMEOUT_SECONDS=8
LOGRIPPER_QRZ_MAX_RETRIES=2

# Optional active station profile used as the base snapshot for newly logged QSOs.
# LOGRIPPER_STATION_PROFILE_NAME=Home
# LOGRIPPER_STATION_CALLSIGN=K7DBG
# LOGRIPPER_STATION_OPERATOR_CALLSIGN=K7DBG
# LOGRIPPER_STATION_OPERATOR_NAME=Taylor Operator
# LOGRIPPER_STATION_GRID=CN87up
# LOGRIPPER_STATION_COUNTY=KING
# LOGRIPPER_STATION_STATE=WA
# LOGRIPPER_STATION_COUNTRY=United States
# LOGRIPPER_STATION_DXCC=291
# LOGRIPPER_STATION_CQ_ZONE=3
# LOGRIPPER_STATION_ITU_ZONE=6
# LOGRIPPER_STATION_LATITUDE=47.6062
# LOGRIPPER_STATION_LONGITUDE=-122.3321
