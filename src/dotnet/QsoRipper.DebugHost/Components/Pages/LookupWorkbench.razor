@page "/lookup-workbench"
@using System.Globalization
@using System.Text
@using QsoRipper.Domain
@inject DebugWorkbenchState WorkbenchState
@inject RuntimeConfigWorkbenchService RuntimeConfigWorkbenchService
@inject LookupWorkbenchService LookupWorkbenchService
@inject SampleProtoFactory SampleProtoFactory
@inject ProtoJsonService ProtoJsonService

<PageTitle>Callsign Lookup Workbench</PageTitle>

<h1 class="mb-3">Callsign Lookup Workbench</h1>
<p class="text-muted">
    This page is the first feature-shaped debugging slice: build a lookup request, inspect its protobuf payload, preview the result UI with sample data, and exercise live unary, streaming, and cache-only lookup calls against the Rust service host.
</p>

<div class="alert alert-secondary">
    <div><strong>Current engine endpoint:</strong> @WorkbenchState.EngineEndpoint</div>
    @if (WorkbenchState.RuntimeConfigSnapshot is not null)
    {
        <div class="mt-1"><strong>Lookup provider:</strong> @WorkbenchState.RuntimeConfigSnapshot.LookupProviderSummary</div>
    }
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label" for="lookup-callsign">Callsign</label>
                <InputText id="lookup-callsign" class="form-control" @bind-Value="callsign" />
            </div>
            <div class="col-md-3">
                <div class="form-check mb-2">
                    <InputCheckbox id="skip-cache" class="form-check-input" @bind-Value="skipCache" />
                    <label class="form-check-label" for="skip-cache">Skip cache</label>
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2 flex-wrap">
                <button class="btn btn-outline-primary" @onclick="Preview">Preview</button>
                <button class="btn btn-primary" @onclick="RunUnaryAsync">Live lookup</button>
                <button class="btn btn-outline-secondary" @onclick="RunStreamingAsync">Stream lookup</button>
                <button class="btn btn-outline-dark" @onclick="RunCacheAsync">Cache lookup</button>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-6">
        <PayloadCard Title="Request payload"
                     Payload="@requestPayload.Json" />
    </div>
    <div class="col-xl-6">
        <PayloadCard Title="Sample result preview"
                     Payload="@samplePayload.Json" />
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2 class="h5 mb-0">Live invocation</h2>
            @if (liveResult is not null)
            {
                <span class="badge @(liveResult.Succeeded ? "text-bg-success" : "text-bg-danger")">
                    @(liveResult.Succeeded ? "Completed" : "Failed")
                </span>
            }
        </div>

        @if (liveResult is null)
        {
            <p class="text-muted mb-0">No live invocation yet. Use the buttons above to exercise the current endpoint.</p>
        }
        else
        {
            <div class="mb-3">
                <strong>Mode:</strong> @liveResult.InvocationMode<br />
                <strong>Completed:</strong> @liveResult.CompletedAtUtc.LocalDateTime.ToString("g")
            </div>

            @if (!string.IsNullOrWhiteSpace(liveResult.ErrorMessage))
            {
                <div class="alert alert-danger">
                    @liveResult.ErrorMessage
                </div>
            }

            @if (livePayloads.Count == 0)
            {
                <p class="text-muted mb-0">No response payloads were returned.</p>
            }
            else
            {
                @for (var i = 0; i < livePayloads.Count; i++)
                {
                    <div class="mb-3">
                        <PayloadCard Title="@($"Response {i + 1}")"
                                     Payload="@livePayloads[i].Json" />
                    </div>
                }
            }

            <div class="mt-4">
                <h3 class="h6">Provider exchanges</h3>
                <p class="text-muted small">
                    Redacted raw provider request and response capture for this invocation.
                </p>

                @if (debugExchangePayloads.Count == 0)
                {
                    <p class="text-muted mb-0">No provider HTTP exchanges were captured for this invocation.</p>
                }
                else
                {
                    @for (var i = 0; i < debugExchangePayloads.Count; i++)
                    {
                        <div class="mb-3">
                            <PayloadCard Title="@debugExchangePayloads[i].Title"
                                         BadgeText="@debugExchangePayloads[i].BadgeText"
                                         Payload="@debugExchangePayloads[i].Payload" />
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@code {
    private string callsign = "K7DBG";
    private bool skipCache;
    private ProtoPayloadView requestPayload = new("{}", string.Empty, 0);
    private ProtoPayloadView samplePayload = new("{}", string.Empty, 0);
    private LookupInvocationResult? liveResult;
    private List<ProtoPayloadView> livePayloads = [];
    private List<DebugExchangePayload> debugExchangePayloads = [];

    protected override async Task OnInitializedAsync()
    {
        await RuntimeConfigWorkbenchService.RefreshAsync();
        Preview();
    }

    private void Preview()
    {
        var request = SampleProtoFactory.CreateLookupRequest(callsign, skipCache);
        requestPayload = ProtoJsonService.Describe(request);
        samplePayload = ProtoJsonService.Describe(SampleProtoFactory.CreateLookupResult(callsign, cacheHit: !skipCache));
    }

    private async Task RunUnaryAsync()
    {
        Preview();
        var request = SampleProtoFactory.CreateLookupRequest(callsign, skipCache);
        liveResult = await LookupWorkbenchService.RunLookupAsync(request);
        livePayloads = liveResult.Responses.Select(ProtoJsonService.Describe).ToList();
        debugExchangePayloads = BuildDebugExchangePayloads(liveResult);
    }

    private async Task RunStreamingAsync()
    {
        Preview();
        var request = SampleProtoFactory.CreateLookupRequest(callsign, skipCache);
        liveResult = await LookupWorkbenchService.RunStreamingLookupAsync(request);
        livePayloads = liveResult.Responses.Select(ProtoJsonService.Describe).ToList();
        debugExchangePayloads = BuildDebugExchangePayloads(liveResult);
    }

    private async Task RunCacheAsync()
    {
        Preview();
        liveResult = await LookupWorkbenchService.RunCachedLookupAsync(callsign);
        livePayloads = liveResult.Responses.Select(ProtoJsonService.Describe).ToList();
        debugExchangePayloads = BuildDebugExchangePayloads(liveResult);
    }

    private static List<DebugExchangePayload> BuildDebugExchangePayloads(LookupInvocationResult? result)
    {
        if (result is null)
        {
            return [];
        }

        return result.DebugHttpExchanges
            .Select(static (exchange, index) => new DebugExchangePayload(
                $"Provider exchange {index + 1}",
                $"{exchange.ProviderName} / {exchange.Operation} / attempt {exchange.Attempt}",
                FormatDebugHttpExchange(exchange)))
            .ToList();
    }

    private static string FormatDebugHttpExchange(DebugHttpExchange exchange)
    {
        var builder = new StringBuilder();
        builder.AppendLine($"Provider: {exchange.ProviderName}");
        builder.AppendLine($"Operation: {exchange.Operation}");

        if (exchange.StartedAtUtc is not null)
        {
            builder.AppendLine(
                $"Started (UTC): {exchange.StartedAtUtc.ToDateTime().ToUniversalTime().ToString("u", CultureInfo.InvariantCulture)}");
        }

        builder.AppendLine($"Attempt: {exchange.Attempt}");
        builder.AppendLine($"Duration: {exchange.DurationMs} ms");
        builder.AppendLine($"Method: {exchange.Method}");
        builder.AppendLine($"URL: {exchange.Url}");
        builder.AppendLine();
        builder.AppendLine("Request headers:");
        AppendHeaders(builder, exchange.RequestHeaders);

        if (exchange.HasRequestBody)
        {
            builder.AppendLine();
            builder.AppendLine("Request body:");
            builder.AppendLine(exchange.RequestBody);
        }

        builder.AppendLine();
        builder.AppendLine(
            exchange.HasResponseStatusCode
                ? $"Response status: {exchange.ResponseStatusCode}"
                : "Response status: <not available>");
        builder.AppendLine("Response headers:");
        AppendHeaders(builder, exchange.ResponseHeaders);

        if (exchange.HasErrorMessage)
        {
            builder.AppendLine();
            builder.AppendLine("Error:");
            builder.AppendLine(exchange.ErrorMessage);
        }

        if (exchange.HasResponseBody)
        {
            builder.AppendLine();
            builder.AppendLine("Response body:");
            builder.AppendLine(exchange.ResponseBody);
        }

        return builder.ToString().TrimEnd();
    }

    private static void AppendHeaders(StringBuilder builder, IEnumerable<DebugHttpHeader> headers)
    {
        var wroteHeader = false;
        foreach (var header in headers)
        {
            wroteHeader = true;
            builder.AppendLine($"{header.Name}: {header.Value}");
        }

        if (!wroteHeader)
        {
            builder.AppendLine("<none>");
        }
    }

    private sealed record DebugExchangePayload(string Title, string BadgeText, string Payload);
}
