@page "/"
@inject DebugWorkbenchState WorkbenchState

<PageTitle>Debug Workbench</PageTitle>

<div class="mb-4">
    <h1 class="mb-2">Developer Debug Workbench</h1>
    <p class="lead mb-2">
        Internal tooling for exercising QsoRipper's engine boundaries before product UX is built.
    </p>
    <p class="text-muted mb-0">
        This host is intentionally developer-focused: inspect protobuf payloads, configure an engine endpoint, run repeatable commands, and wire future live gRPC flows into a stable workbench.
    </p>
</div>

<div class="alert alert-secondary">
    <strong>Current engine endpoint:</strong> @WorkbenchState.EngineEndpoint
</div>

<div class="row g-4">
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Engine Session</h2>
                <p class="text-muted">Configure the target Rust endpoint, probe transport reachability, and hot-apply supported storage and QRZ runtime overrides.</p>
                <a class="btn btn-primary" href="engine">Open engine tools</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Protobuf Lab</h2>
                <p class="text-muted">Generate sample domain and service payloads, then inspect JSON and raw protobuf output side-by-side.</p>
                <a class="btn btn-primary" href="protobuf-lab">Open protobuf lab</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Callsign Lookup</h2>
                <p class="text-muted">Preview lookup requests now and invoke the live gRPC path as soon as the Rust lookup host is available.</p>
                <a class="btn btn-primary" href="lookup-workbench">Open lookup workbench</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Storage Workbench</h2>
                <p class="text-muted">Exercise logbook CRUD through gRPC, compare memory vs SQLite sessions, and verify persistence behavior after engine restarts.</p>
                <a class="btn btn-primary" href="storage-workbench">Open storage workbench</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">ADIF &amp; Sync</h2>
                <p class="text-muted">Import/export ADIF, run QRZ logbook sync, and inspect streamed interop/status payloads through the live logbook service.</p>
                <a class="btn btn-primary" href="logbook-interop">Open ADIF &amp; sync tools</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">QSO Viewer</h2>
                <p class="text-muted">Inspect stored QSOs through the shared gRPC surface with filters and side-by-side record detail output.</p>
                <a class="btn btn-primary" href="qso-viewer">Open QSO viewer</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Commands & Tests</h2>
                <p class="text-muted">Run curated Rust/.NET validation commands from an allowlisted catalog and capture their output.</p>
                <a class="btn btn-primary" href="commands">Open command runner</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Rig Control</h2>
                <p class="text-muted">Exercise the rig control gRPC service: query rig status, read frequency/band/mode from rigctld, and test connectivity.</p>
                <a class="btn btn-primary" href="rig-control">Open rig control</a>
            </div>
        </div>
    </div>
</div>

<div class="mt-4 card shadow-sm">
    <div class="card-body">
        <h2 class="h5">What this first implementation covers</h2>
        <ul class="mb-0">
            <li>A permanent Blazor Server host under <code>src/dotnet/</code>.</li>
            <li>Real C# protobuf and gRPC client generation from the shared <code>proto/</code> contracts.</li>
            <li>Developer tooling that stays on the engine boundary instead of recreating business logic in .NET.</li>
            <li>Dedicated workbenches for runtime config, lookup, storage, ADIF interchange, and logbook sync workflows.</li>
        </ul>
    </div>
</div>
