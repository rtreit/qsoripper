<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="using:QsoRipper.Shared.Persistence"
             xmlns:vm="using:QsoRipper.Gui.ViewModels"
             x:Class="QsoRipper.Gui.Views.LogFileStepView"
             x:DataType="vm:LogFileStepViewModel">

  <StackPanel Spacing="12">
    <ItemsControl ItemsSource="{Binding PersistenceFields}"
                  IsVisible="{Binding HasPersistenceInputs}">
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="shared:PersistenceSetupField">
          <StackPanel Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}"
                       IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Opacity="0.7"
                       TextWrapping="Wrap"
                       FontSize="12" />
            <ComboBox ItemsSource="{Binding AllowedValues}"
                      SelectedItem="{Binding Value, Mode=TwoWay}"
                      IsVisible="{Binding HasChoices}" />
            <TextBox Text="{Binding Value, Mode=TwoWay}"
                     IsVisible="{Binding !HasChoices}" />
          </StackPanel>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <TextBlock Text="No additional persistence input is required for this engine."
               IsVisible="{Binding ShowsInfoOnly}"
               Opacity="0.8"
               TextWrapping="Wrap" />
  </StackPanel>
</UserControl>
